# Google Apps Script Web App URL for Sheets/Gmail integration
# Set this to your deployed Google Apps Script Web App URL
VITE_GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# Meta (Facebook) Pixel + Conversions API Tracking
# Get these from Meta Events Manager → Settings
META_PIXEL_ID=YOUR_PIXEL_ID_HERE
META_CAPI_ACCESS_TOKEN=YOUR_ACCESS_TOKEN_HERE
